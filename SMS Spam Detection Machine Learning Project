lly longer.\ndf[\"text\"] = df[\"text\"].str.lower()\ndf[\"char_cnt\"]     = df[\"text\"].str.len()\ndf[\"word_cnt\"]     = df[\"text\"].str.split().str.len()\ndf[\"avg_word_len\"] = df[\"char_cnt\"] / df[\"word_cnt\"]\n\ndf.head()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T03:02:44.193043Z","iopub.execute_input":"2026-06-29T03:02:44.193434Z","iopub.status.idle":"2026-06-29T03:02:44.225477Z","shell.execute_reply.started":"2026-06-29T03:02:44.193382Z","shell.execute_reply":"2026-06-29T03:02:44.224513Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Visualizing the numbers\nfig, axes = plt.subplots(1, 3, figsize=(14, 4))\nfeatures = [\"char_cnt\", \"word_cnt\", \"avg_word_len\"]\n\nfor ax, feat in zip(axes, features):\n    for label, color in [(\"ham\", \"blue\"), (\"spam\", \"red\")]:\n        df[df[\"label\"] == label][feat].plot(\n            kind=\"hist\", bins=40, alpha=0.6, color=color, label=label, ax=ax\n        )\n    ax.set_title(feat)\n    ax.legend()\n\nplt.suptitle(\"Feature distributions by class\", y=1.02, fontsize=13)\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T03:02:44.226709Z","iopub.execute_input":"2026-06-29T03:02:44.227027Z","iopub.status.idle":"2026-06-29T03:02:45.125208Z","shell.execute_reply.started":"2026-06-29T03:02:44.226987Z","shell.execute_reply":"2026-06-29T03:02:45.124379Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"numberic_df= df.select_dtypes(include=['number'])\nsns.heatmap(numberic_df.corr(), annot=True)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T03:02:45.126253Z","iopub.execute_input":"2026-06-29T03:02:45.12651Z","iopub.status.idle":"2026-06-29T03:02:45.359928Z","shell.execute_reply.started":"2026-06-29T03:02:45.126485Z","shell.execute_reply":"2026-06-29T03:02:45.359081Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Splitting data and Text Vectorization","metadata":{}},{"cell_type":"code","source":"#Splitting data\nX_train, X_test, y_train, y_test= train_test_split(\n    df['text'],\n    df['label_enc'],\n    test_size=0.2,\n    random_state=42\n)\nX_train_np= X_train.to_numpy()\nX_test_np= X_test.to_numpy()\ny_train_np= y_train.to_numpy()\ny_test_np= y_test.to_numpy()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T03:02:45.361199Z","iopub.execute_input":"2026-06-29T03:02:45.361586Z","iopub.status.idle":"2026-06-29T03:02:45.370014Z","shell.execute_reply.started":"2026-06-29T03:02:45.36153Z","shell.execute_reply":"2026-06-29T03:02:45.369143Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#computing text stats for vectorization\navg_words_len = round(sum([len(i.split())\n          for i in df['text']]) / len(df['text']))\ntotal_words_length = len(set(\"\".join(df['text']).split()))\nprint(f\"Data Loaded. Training samples: {len(X_train_np)}\")\nprint(f\"Average words per message: {avg_words_len}\")\nprint(f\"Approximate vocabulary size: {total_words_length}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T03:02:45.372625Z","iopub.execute_input":"2026-06-29T03:02:45.373002Z","iopub.status.idle":"2026-06-29T03:02:45.407781Z","shell.execute_reply.started":"2026-06-29T03:02:45.372974Z","shell.execute_reply":"2026-06-29T03:02:45.406811Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Helper functions\ndef compile_and_fit(model, epochs=5):\n    model.compile(\n        optimizer='adam',\n        loss='binary_crossentropy',\n        metrics=['accuracy']\n    )\n    history = model.fit(\n        X_train_np,\n        y_train_np,\n        epochs=epochs,\n        validation_data=(X_test_np, y_test_np)\n    )\n    return history\ndef get_metrics(model, X, y):\n    y_preds = np.round(model.predict(X))\n    return {\n        'accuracy': accuracy_score(y,y_preds),\n        'precision': precision_score(y,y_preds),\n        'recall': recall_score(y, y_preds),\n        'f1-score': f1_score(y, y_preds)\n    }","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T03:02:45.408924Z","iopub.execute_input":"2026-06-29T03:02:45.409784Z","iopub.status.idle":"2026-06-29T03:02:45.420976Z","shell.execute_reply.started":"2026-06-29T03:02:45.409755Z","shell.execute_reply":"2026-06-29T03:02:45.42005Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Text Vectorization layer\nfrom tensorflow.keras.layers import TextVectorization\ntext_vec = TextVectorization(\n    max_tokens=total_words_length,\n    standardize= 'lower_and_strip_punctuation',\n    output_mode='int',\n    output_sequence_length=avg_words_len\n)\ntext_vec.adapt(X_train_np)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T03:03:56.027028Z","iopub.execute_input":"2026-06-29T03:03:56.027364Z","iopub.status.idle":"2026-06-29T03:03:56.095558Z","shell.execute_reply.started":"2026-06-29T03:03:56.027337Z","shell.execute_reply":"2026-06-29T03:03:56.09471Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Building and Training the Models","metadata":{}},{"cell_type":"code","source":"#Dense embedding model\ninput_layer = layers.Input(shape=(1,), dtype=tf.string)\nx = text_vec(input_layer)\nx = layers.Embedding(input_dim=total_words_length, output_dim=128)(x)\nx = layers.GlobalAveragePooling1D()(x)\nx = layers.Dense(32, activation='relu')(x)\noutput_layer = layers.Dense(1, activation='sigmoid')(x)\nmodel_1 = keras.Model(input_layer, output_layer, name=\"Dense_Model\")\nhistory_1 = compile_and_fit(model_1)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T03:02:45.602329Z","iopub.execute_input":"2026-06-29T03:02:45.602696Z","iopub.status.idle":"2026-06-29T03:02:54.169621Z","shell.execute_reply.started":"2026-06-29T03:02:45.602662Z","shell.execute_reply":"2026-06-29T03:02:54.168853Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Bidirectional LSTM Model, Building and Training\ninput_layer = layers.Input(shape=(1,), dtype=tf.string)\nx = text_vec(input_layer)\nx = layers.Embedding(input_dim=total_words_length, output_dim=128)(x)\nx = layers.Bidirectional(layers.LSTM(64, return_sequences=True))(x)\nx = layers.Bidirectional(layers.LSTM(64))(x)\nx = layers.Flatten()(x)\nx = layers.Dropout(0.1)(x)\nx = layers.Dense(32, activation='relu')(x)\noutput_layer = layers.Dense(1, activation='sigmoid')(x)\nmodel_2 = keras.Model(input_layer, output_layer, name=\"BiLSTM_Model\")\nhistory_2= compile_and_fit(model_2)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T03:02:54.17063Z","iopub.execute_input":"2026-06-29T03:02:54.170933Z","iopub.status.idle":"2026-06-29T03:03:21.952863Z","shell.execute_reply.started":"2026-06-29T03:02:54.170899Z","shell.execute_reply":"2026-06-29T03:03:21.95191Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Universal Sentence Encoder for transferring learning\nuse_layer = hub.KerasLayer(\n    \"https://tfhub.dev/google/universal-sentence-encoder/4\",\n    trainable=False,\n    input_shape=[],\n    dtype=tf.string,\nname='USE'\n)\ninput_layer = layers.Input(shape=[], dtype=tf.string)\nembedding = layers.Lambda(lambda x: use_layer(\n    x), output_shape=(512,))(input_layer)\nx = layers.Dense(64, activation='relu')(embedding)\nx = layers.Dropout(0.2)(x)\noutput_layer = layers.Dense(1, activation='sigmoid')(x)\nmodel_3 = keras.Model(input_layer, output_layer, name=\"USE_Model\")\nhistory_3 = compile_and_fit(model_3)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T03:03:21.953939Z","iopub.execute_input":"2026-06-29T03:03:21.954253Z","iopub.status.idle":"2026-06-29T03:03:52.541448Z","shell.execute_reply.started":"2026-06-29T03:03:21.954225Z","shell.execute_reply":"2026-06-29T03:03:52.54051Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Collecting performance metrics for all models\nresults = {\n    'Dense Embedding': get_metrics(model_1, X_test_np, y_test_np),\n    'Bi-LSTM': get_metrics(model_2, X_test_np, y_test_np),\n    'Transfer Learning (USE)': get_metrics(model_3, X_test_np, y_test_np)\n}\nresults_df = pd.DataFrame(results).transpose()\nprint(\"Performance Table:\")\nprint(results_df)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T03:03:52.542612Z","iopub.execute_input":"2026-06-29T03:03:52.542931Z","iopub.status.idle":"2026-06-29T03:03:55.600693Z","shell.execute_reply.started":"2026-06-29T03:03:52.542896Z","shell.execute_reply":"2026-06-29T03:03:55.599884Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Results","metadata":{}},{"cell_type":"code","source":"#Visualizing Results\nresults_df.plot(kind='bar', figsize=(10, 6))\nplt.title(\"Model Performance Metrics (Bar Chart)\")\nplt.ylabel(\"Score\")\nplt.ylim(0.8, 1.0)\nplt.xticks(rotation=0)\nplt.legend(loc='lower right')\nplt.grid(axis='y', linestyle='--', alpha=0.7)\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T03:03:55.601697Z","iopub.execute_input":"2026-06-29T03:03:55.601998Z","iopub.status.idle":"2026-06-29T03:03:55.807169Z","shell.execute_reply.started":"2026-06-29T03:03:55.601971Z","shell.execute_reply":"2026-06-29T03:03:55.806264Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"plt.figure(figsize=(10, 6))\n\nfor model_name in results_df.index:\n    plt.plot(\n        results_df.columns,\n        results_df.loc[model_name],\n        marker='o',\n        label=model_name,\n        linewidth=2\n    )\nplt.title(\"Model Performance Trends (Line Graph)\")\nplt.ylabel(\"Score\")\nplt.xlabel(\"Metric\")\nplt.ylim(0.8, 1.0)\nplt.grid(True, linestyle='--', alpha=0.6)\nplt.legend()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T03:05:01.176772Z","iopub.execute_input":"2026-06-29T03:05:01.177153Z","iopub.status.idle":"2026-06-29T03:05:01.370233Z","shell.execute_reply.started":"2026-06-29T03:05:01.177122Z","shell.execute_reply":"2026-06-29T03:05:01.369258Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# CONCLUSION\n\nBased on what’s shown in the graphs, it seems that the **Transfer Learning (USE)** seems to be the most effective in spam detection for this dataset due to its high accuracy score and F1 score. Additionally, it requires significantly less data due to its pre-trained embeddings. Though it requires a deeper contextual understanding of sequences, this can be helpful in this project for filtering out spam emails. While the other two models all achieved similar results on average, they both have a significantly lower recall score than the Transfer Learning (USE) model. This may increase the risk of legitimate emails being wrongly blocked.","metadata":{}}]}